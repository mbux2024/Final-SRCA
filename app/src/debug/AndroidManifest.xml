<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only manifest overlay. Points the debug build at a network security
  config that also trusts user-installed CAs, so the app can talk to TMDB/etc.
  through a proxy/VPN whose CA you've added to the emulator. Merged only into
  debug builds; release builds are unaffected.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
